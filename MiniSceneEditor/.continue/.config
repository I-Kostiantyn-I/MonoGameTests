{
  "contextProviders": [
    {
      "name": "MonoGame Framework",
      "provider": "filesystem",
      "options": {
        "paths": [
          "../librariesSourceCode/Monogame/MonoGame.Framework"
        ],
        "include": [
          "**/*.cs"
        ],
        "exclude": [
          "**/bin/**",
          "**/obj/**",
          "**/.vs/**",
          "**/Properties/AssemblyInfo.cs",
          "**/packages/**"
        ]
      },
      "metadata": {
        "type": "framework",
        "library": "monogame"
      },
      "tags": ["monogame", "framework"]
    },
    {
      "name": "MonoGame Extended",
      "provider": "filesystem",
      "options": {
        "paths": [
          "../librariesSourceCode/MonoGame.Extended/src"
        ],
        "include": [
          "**/*.cs"
        ],
        "exclude": [
          "**/bin/**",
          "**/obj/**",
          "**/.vs/**",
          "**/Properties/AssemblyInfo.cs",
          "**/packages/**"
        ]
      },
      "metadata": {
        "type": "framework",
        "library": "extended"
      },
      "tags": ["monogame", "extended"]
    },
    {
      "name": "MonoGame API Documentation",
      "provider": "filesystem",
      "options": {
        "paths": ["../documentation/docs.monogame.net/api"],
        "include": ["**/*.xml", "**/*.html", "**/*.md"],
        "exclude": ["**/assets/**", "**/js/**", "**/css/**"]
      },
      "tags": ["monogame", "api-docs"]
    },
    {
      "name": "MonoGame Wiki",
      "provider": "filesystem",
      "options": {
        "paths": ["../documentation/deepwiki-monogame"],
        "include": ["**/*.md", "**/*.html"],
        "exclude": ["**/assets/**", "**/js/**", "**/css/**"]
      },
      "tags": ["monogame", "wiki", "guides"]
    }
  ],
  "models": {
    "default": {
      "provider": "ollama",
      "model": "deepseek-r1:14b-qwen-distill-q4_K_M",
      "embeddingModel": "nomic-embed-text"
    }
  }
}