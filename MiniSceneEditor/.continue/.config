{
  "contextProviders": [
    {
      "name": "MonoGame Framework",
      "provider": "filesystem",
      "options": {
        "paths": [
          "../librariesSourceCode/MonoGame v3.8.2.1105/MonoGame.Framework"
        ],
        "include": [
          "**/*.cs"
        ],
        "exclude": [
          "**/bin/**",
          "**/obj/**",
          "**/.vs/**",
          "**/Properties/AssemblyInfo.cs",
          "**/packages/**"
        ]
      },
      "metadata": {
        "type": "framework",
        "version": "3.8.2.1105",
        "library": "monogame"
      },
      "tags": ["monogame", "framework"]
    },
    {
      "name": "BEPUphysics2",
      "provider": "filesystem",
      "options": {
        "paths": [
          "../librariesSourceCode/bepuphysics2 v2.4.0"
        ],
        "include": [
          "**/*.cs"
        ],
        "exclude": [
          "**/bin/**",
          "**/obj/**",
          "**/.vs/**",
          "**/Properties/AssemblyInfo.cs",
          "**/packages/**"
        ]
      },
      "metadata": {
        "type": "physics",
        "version": "2.4.0",
        "library": "bepu"
      },
      "tags": ["bepu", "physics"]
    },
    {
      "name": "ImGui.NET",
      "provider": "filesystem",
      "options": {
        "paths": [
          "../librariesSourceCode/ImGui.NET v1.91.6.1"
        ],
        "include": [
          "**/*.cs"
        ],
        "exclude": [
          "**/bin/**",
          "**/obj/**",
          "**/.vs/**",
          "**/Properties/AssemblyInfo.cs",
          "**/packages/**"
        ]
      },
      "metadata": {
        "type": "ui",
        "version": "1.91.6.1",
        "library": "imgui"
      },
      "tags": ["imgui", "ui"]
    },
    {
      "name": "MonoGame API Documentation",
      "provider": "filesystem",
      "options": {
        "paths": ["../documentation/docs.monogame.net/api"],
        "include": ["**/*.xml", "**/*.html", "**/*.md"],
        "exclude": ["**/assets/**", "**/js/**", "**/css/**"]
      },
      "tags": ["monogame", "api-docs"]
    },
    {
      "name": "MonoGame Wiki",
      "provider": "filesystem",
      "options": {
        "paths": ["../documentation/deepwiki-monogame"],
        "include": ["**/*.md", "**/*.html"],
        "exclude": ["**/assets/**", "**/js/**", "**/css/**"]
      },
      "tags": ["monogame", "wiki", "guides"]
    },
    {
      "name": "BEPUphysics2 Wiki",
      "provider": "filesystem",
      "options": {
        "paths": ["../documentation/deepwiki-bepuphysics2"],
        "include": ["**/*.md", "**/*.html"],
        "exclude": ["**/assets/**", "**/js/**", "**/css/**"]
      },
      "tags": ["bepu", "physics", "wiki", "guides"]
    }
  ],
  "models": {
    "default": {
      "provider": "ollama",
      "model": "deepseek-r1:14b-qwen-distill-q4_K_M",
      "embeddingModel": "nomic-embed-text"
    }
  }
}